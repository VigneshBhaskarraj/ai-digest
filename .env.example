# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API (primary summarization model)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Multi-model synthesis (OpenRouter) ────────────────────────────────────────
# Used for the signal extraction layer and multi-model synthesis pass.
# Free tier available. Get from: https://openrouter.ai/keys
# Add as GitHub Actions secret: OPENROUTER_API_KEY
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# ── Optional / Not currently active ──────────────────────────────────────────

# NewsAPI key (not currently used — RSS covers all sources)
# NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email delivery (disabled — see send_email.py)
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASS=xxxx xxxx xxxx xxxx
# DIGEST_RECIPIENT=your@email.com
